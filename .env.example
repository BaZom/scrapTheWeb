APP_ENV=local
LOG_LEVEL=info
DATABASE_URL=postgresql+asyncpg://scraptheweb:scraptheweb@db:5432/scraptheweb
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=scraptheweb-local
S3_REGION=us-east-1
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-local-secret
JWT_ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_SECRET=replace-with-another-long-random-local-secret
REFRESH_TOKEN_DAYS=30
RENDER_RESULT_TIMEOUT_SECONDS=20
PAGE_SESSION_TTL_SECONDS=3600
RENDER_NAVIGATION_TIMEOUT_MS=20000
RENDER_RATE_LIMIT_PER_HOUR=30
RECIPE_RUN_RATE_LIMIT_PER_HOUR=20
EXPORT_RATE_LIMIT_PER_HOUR=60
ORG_RENDER_QUOTA_PER_MONTH=200
ORG_RECIPE_RUN_QUOTA_PER_MONTH=100
ORG_EXPORT_QUOTA_PER_MONTH=500
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api:8000
# Observability. All are optional; leave empty for local development.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_CONSOLE_EXPORTER=false
OTEL_SERVICE_NAME_API=scraptheweb-api
OTEL_SERVICE_NAME_WORKER=scraptheweb-worker
WORKER_METRICS_PORT=9100
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=local
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.0

# Auth + security. Local-safe defaults.
EMAIL_VERIFICATION_TOKEN_HOURS=48
PASSWORD_RESET_TOKEN_MINUTES=30
REQUIRE_EMAIL_VERIFICATION=false
CORS_ALLOWED_ORIGINS=http://localhost:3000
